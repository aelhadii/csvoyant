# ─────────────────────────────────────────────────────────────────────────────
# CSVoyant configuration. Copy to `.env` and fill in. docker-compose reads this file.
# Every value the stack needs is listed here (DECISIONS: config via env only).
# ─────────────────────────────────────────────────────────────────────────────

# --- PostgreSQL (application state: users, jobs, dashboards) ---
POSTGRES_USER=csvoyant
POSTGRES_PASSWORD=csvoyant
POSTGRES_DB=csvoyant
# Consumed by the Rust services. Host `postgres` is the compose service name.
DATABASE_URL=postgres://csvoyant:csvoyant@postgres:5432/csvoyant

# --- ClickHouse (analytics store: ingested CSV data) ---
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=default

# --- RabbitMQ (job queue) ---
RABBITMQ_DEFAULT_USER=csvoyant
RABBITMQ_DEFAULT_PASS=csvoyant
AMQP_URL=amqp://csvoyant:csvoyant@rabbitmq:5672/%2f

# --- API ---
BIND_ADDR=0.0.0.0:8080
# Secret used to sign JWTs (Prompt B). CHANGE THIS in any real deployment.
JWT_SECRET=dev-insecure-change-me
# Log filter (tracing EnvFilter syntax).
RUST_LOG=info,api=debug,worker=debug,shared=debug

# --- Worker ---
WORKER_HEALTH_ADDR=0.0.0.0:8081

# --- Observability / Axiom (OpenTelemetry over OTLP-HTTP) ---
# Leave OTLP_ENDPOINT empty to disable export (stdout logging still works).
# For Axiom: https://api.axiom.co
OTLP_ENDPOINT=
AXIOM_TOKEN=
AXIOM_DATASET=csvoyant

# --- Frontend ---
# Base URL the browser uses to reach the API.
NEXT_PUBLIC_API_URL=http://localhost:8080
